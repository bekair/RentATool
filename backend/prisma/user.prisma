model User {
  id               String           @id @default(uuid())
  email            String           @unique
  passwordHash     String
  verificationTier VerificationTier @default(UNVERIFIED)
  verifiedAt       DateTime?
  profile          UserProfile?
  tools            Tool[]
  addresses        Address[]
  paymentProfile   PaymentProfile?
  bookings         Booking[]        @relation("RenterBookings")
  receivedBookings Booking[]        @relation("OwnerBookings")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@map("users")
}

model UserProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String?
  firstName   String
  lastName    String
  birthDate   DateTime? @db.Date
  region      String? // country name e.g. "Belgium"
  phone       String? // full number with dial code e.g. "+32470000000"
  phoneCode   String? // dial code e.g. "+32"
  phoneNumber String? // local number e.g. "470000000"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("user_profiles")
}

model Address {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  label        String // "Home", "Work", or custom
  street       String?
  addressLine2 String? // Apt, suite, floor, unit, etc.
  city         String?
  state        String?
  postalCode   String?
  country      String?
  latitude     Float?
  longitude    Float?
  isDefault    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("addresses")
}
