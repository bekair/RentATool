model Category {
  id           String        @id @default(uuid())
  name         String
  slug         String        @unique
  icon         String?
  parentId     String?
  parent       Category?     @relation("Subcategories", fields: [parentId], references: [id])
  children     Category[]    @relation("Subcategories")
  toolVersions ToolVersion[]
  createdAt    DateTime      @default(now())

  @@map("categories")
}

model Tool {
  id          String          @id @default(uuid())
  ownerId     String
  owner       User            @relation(fields: [ownerId], references: [id])
  isAvailable Boolean         @default(true)

  // The spotlight pointer to the currently active content version
  activeVersionId String?      @unique
  activeVersion   ToolVersion? @relation("ActiveVersion", fields: [activeVersionId], references: [id])

  // History tracking
  allVersions ToolVersion[] @relation("AllVersions")

  bookings  Booking[] // The meta relationship
  blocks    ToolDateBlock[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tools")
}

model ToolVersion {
  id     String @id @default(uuid())
  toolId String
  tool   Tool   @relation("AllVersions", fields: [toolId], references: [id], onDelete: Cascade)

  // The mutable tool content
  name             String
  description      String
  categoryId       String
  category         Category @relation(fields: [categoryId], references: [id])
  pricePerDay      Float
  replacementValue Float?
  condition        String?
  latitude         Float?
  longitude        Float?
  images           String[] @default([])

  // Inverse relationship for the active spotlight
  activeForTool Tool? @relation("ActiveVersion")

  // Bookings point directly to the specific version to freeze historical price/data
  bookings Booking[]

  createdAt DateTime @default(now())

  @@map("tool_versions")
}

model ToolDateBlock {
  id        String   @id @default(uuid())
  toolId    String
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date // The specific day being blocked
  reason    String? // e.g., "maintenance", "vacation" (optional for future use)
  createdAt DateTime @default(now())

  // Ensure a tool can't have duplicate block entries for the exact same day
  @@unique([toolId, date])
  @@map("tool_date_blocks")
}
